# Local development environment variables
# Copy this file to .env and update the values before starting the server.

# Database configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=transitops

# MongoDB is also supported for demo and health checks
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=transitops

# SMTP configuration for email verification and password resets
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
EMAIL_FROM="TransitOps <noreply@transitops.com>"

